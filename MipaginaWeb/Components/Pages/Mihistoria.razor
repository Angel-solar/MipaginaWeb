@page "/mihistoria"

<PageTitle>Mi historia</PageTitle>

<!-- Jumbotron/Header -->
<div class="jumbotron bg-light p-5 rounded-3 mb-4">
    <h1 class="display-4">Mi historia</h1>
    <p class="lead">A continuación les escribiré información relevante de mi vida.</p>
</div>

<!-- Grid de tarjetas -->
<div class="row">
    <!-- Tarjeta 1: Formación -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
            <img src="images/laptop.png" class="card-img-top" alt="Laptop" style="height: 200px; object-fit: cover;">
            <div class="card-body">
                <h5 class="card-title">Formación</h5>
                <p class="card-text">Cuento algo sobre mi formación profesional.</p>
                <a href="#" class="btn btn-primary">Conocer más</a>
            </div>
        </div>
    </div>

    <!-- Tarjeta 2: Hobbies -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
            <img src="images/hobbie.png" class="card-img-top" alt="Desktop" style="height: 200px; object-fit: cover;">
            <div class="card-body">
                <h5 class="card-title">Hobbies</h5>
                <p class="card-text">Cuento algo sobre mis hobbies.</p>
                <a href="#" class="btn btn-primary">Conocer más</a>
            </div>
        </div>
    </div>

    <!-- Tarjeta 3: Mi carrera -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
            <img src="images/carrera.png" class="card-img-top" alt="PC" style="height: 200px; object-fit: cover;">
            <div class="card-body">
                <h5 class="card-title">Mi carrera</h5>
                <p class="card-text">Cuento algo sobre lo que espero de mi carrera.</p>
                <a href="#" class="btn btn-primary">Conocer más</a>
            </div>
        </div>
    </div>
</div>
