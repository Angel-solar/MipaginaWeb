@page "/dias-del-mes"
@rendermode InteractiveServer

<PageTitle>Días del mes</PageTitle>

<h1>Conocer los días del mes</h1>

<div class="row mt-4">
    <div class="col-md-6">
        <form @onsubmit="CalcularDias" @onsubmit:preventDefault>
            <div class="form-group row mb-3">
                <label for="mes" class="col-sm-2 col-form-label">Mes</label>
                <div class="col-sm-10">
                    <input type="number"
                           class="form-control"
                           id="mes"
                           @bind="mes"
                           min="1"
                           max="12"
                           required
                           placeholder="1-12" />
                </div>
            </div>

            <div class="form-group row mb-3">
                <label for="anio" class="col-sm-2 col-form-label">Año</label>
                <div class="col-sm-10">
                    <input type="number"
                           class="form-control"
                           id="anio"
                           @bind="anio"
                           min="1"
                           required
                           placeholder="Ej. 2000" />
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-10 offset-sm-2">
                    <button type="submit" class="btn btn-primary">
                        Calcular
                    </button>
                </div>
            </div>
        </form>

        @if (!string.IsNullOrEmpty(mensajeResultado))
        {
            <div class="mt-4">
                <h3>@mensajeResultado</h3>
            </div>
        }
    </div>
</div>

@code {
    private int mes = 2;
    private int anio = 2000;
    private string? mensajeResultado;

    private void CalcularDias()
    {
        if (mes < 1 || mes > 12)
        {
            mensajeResultado = "Por favor, ingrese un mes válido (1-12).";
            return;
        }

        int dias;
        string nombreMes = ObtenerNombreMes(mes);

        if (mes == 1 || mes == 3 || mes == 5 || mes == 7 ||
            mes == 8 || mes == 10 || mes == 12)
        {
            dias = 31;
        }
        else if (mes == 4 || mes == 6 || mes == 9 || mes == 11)
        {
            dias = 30;
        }
        else // Febrero
        {
            dias = EsBisiesto(anio) ? 29 : 28;
        }

        mensajeResultado = $"El mes {mes} del año {anio} tiene {dias} días";
    }

    private bool EsBisiesto(int year)
    {
        // Regla: múltiplo de 4 y no de 100, o múltiplo de 400
        return (year % 4 == 0 && year % 100 != 0) || (year % 400 == 0);
    }

    private string ObtenerNombreMes(int month)
    {
        return month switch
        {
            1 => "enero",
            2 => "febrero",
            3 => "marzo",
            4 => "abril",
            5 => "mayo",
            6 => "junio",
            7 => "julio",
            8 => "agosto",
            9 => "septiembre",
            10 => "octubre",
            11 => "noviembre",
            12 => "diciembre",
            _ => ""
        };
    }
}