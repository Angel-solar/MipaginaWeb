@page "/lista-actividades"
@rendermode InteractiveServer

<h3>Lista de Actividades</h3>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="input-group">
            <input type="text"
                   class="form-control"
                   placeholder="Escribe una nueva actividad..."
                   @bind="nuevaActividad"
                   @onkeypress="ManejarTecla" />
            <div class="input-group-append">
                <button class="btn btn-success" @onclick="AgregarActividad">
                    <span class="oi oi-plus"></span> Agregar
                </button>
            </div>
        </div>
    </div>
</div>

@if (actividades.Count == 0)
{
    <div class="alert alert-info">
        No hay actividades pendientes. ¡Agrega una nueva!
    </div>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <h5>Actividades por realizar (@actividades.Count)</h5>
            <ul class="list-group">
                @foreach (var actividad in actividades)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>@actividad</span>
                        <button class="btn btn-danger btn-sm" @onclick="() => EliminarActividad(actividad)">
                            <span class="oi oi-trash"></span> Eliminar
                        </button>
                    </li>
                }
            </ul>
            
            <div class="mt-3">
                <button class="btn btn-warning" @onclick="LimpiarLista">
                    <span class="oi oi-delete"></span> Limpiar todas
                </button>
            </div>
        </div>
    </div>
}

@code {
    // Colección para almacenar las actividades
    private List<string> actividades = new List<string>();
    private string nuevaActividad = "";

    private void AgregarActividad()
    {
        if (!string.IsNullOrWhiteSpace(nuevaActividad))
        {
            actividades.Add(nuevaActividad.Trim());
            nuevaActividad = ""; // Limpiar el campo
        }
    }

    private void EliminarActividad(string actividad)
    {
        actividades.Remove(actividad);
    }

    private void LimpiarLista()
    {
        actividades.Clear();
    }

    private void ManejarTecla(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AgregarActividad();
        }
    }
}